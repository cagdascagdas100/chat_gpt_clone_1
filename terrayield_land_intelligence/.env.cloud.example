# TerraYield AI cloud environment template
# Copy these names into your hosting provider dashboard.
# Do not commit real values.
# Keep secret values only in the provider dashboard or a private local environment.

APP_HOST=0.0.0.0
APP_PORT=8010
ALLOWED_ORIGINS=*
AAYS_DEPLOYMENT_MODE=cloud
DATABASE_URL=<SET_IN_PROVIDER_DASHBOARD_ONLY>
TERRAYIELD_PUBLIC_API_URL=https://YOUR_PUBLIC_API_HOST
TERRAYIELD_FRONTEND_PUBLIC_URL=https://YOUR_PUBLIC_FRONTEND_HOST
TERRAYIELD_CLOUD_DB_VERIFIED=false
